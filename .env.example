GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Runtime model is locked in source to the stable Gemini API ID: gemini-3.5-flash

# OpenAI Realtime voice backend. Keep the API key server-side only.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ElevenLabs voice config
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# Optional: point the browser client at a different backend endpoint.
# VITE_GEMINI_API_ENDPOINT=/api/gemini/stream

# Browser-use Python backend (see backend/README.md).
# Start with: cd backend && uvicorn browser_use_server:app --port 8765
VITE_BROWSER_USE_WS_URL=ws://localhost:8765/ws/research
